{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cheguevara-great-man/fanvpn-bridge/contracts/native-messaging-v1.schema.json",
  "title": "FanVPN Bridge Native Messaging Protocol v1",
  "description": "Versioned envelopes exchanged between the native host and the Chrome extension.",
  "oneOf": [
    { "$ref": "#/$defs/hello" },
    { "$ref": "#/$defs/helloAck" },
    { "$ref": "#/$defs/requestHead" },
    { "$ref": "#/$defs/requestBody" },
    { "$ref": "#/$defs/requestAbort" },
    { "$ref": "#/$defs/responseHead" },
    { "$ref": "#/$defs/responseBody" },
    { "$ref": "#/$defs/flowAck" },
    { "$ref": "#/$defs/messageError" },
    { "$ref": "#/$defs/ping" },
    { "$ref": "#/$defs/pong" },
    { "$ref": "#/$defs/controlModeGet" },
    { "$ref": "#/$defs/controlModeSet" },
    { "$ref": "#/$defs/controlModeResult" },
    { "$ref": "#/$defs/controlAntigravityGet" },
    { "$ref": "#/$defs/controlAntigravitySetup" },
    { "$ref": "#/$defs/controlAntigravityResult" }
  ],
  "$defs": {
    "protocolVersion": { "const": 1 },
    "requestId": {
      "type": "string",
      "minLength": 16,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "headers": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "string", "minLength": 1, "maxLength": 256 },
          { "type": "string", "maxLength": 16384 }
        ],
        "items": false,
        "minItems": 2,
        "maxItems": 2
      }
    },
    "browserTiming": {
      "type": "object",
      "required": ["executor_queue_ms", "fetch_head_ms", "attempts", "preemptions"],
      "properties": {
        "executor_queue_ms": { "type": "integer", "minimum": 0, "maximum": 3600000 },
        "fetch_head_ms": { "type": "integer", "minimum": 0, "maximum": 3600000 },
        "attempts": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "preemptions": { "type": "integer", "minimum": 0, "maximum": 10000 }
      },
      "additionalProperties": false
    },
    "base": {
      "type": "object",
      "required": ["v", "type"],
      "properties": {
        "v": { "$ref": "#/$defs/protocolVersion" },
        "type": { "type": "string" }
      }
    },
    "hello": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "host_version", "max_chunk_bytes", "max_in_flight"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "hello" },
            "host_version": { "type": "string", "minLength": 1 },
            "max_chunk_bytes": { "type": "integer", "minimum": 16384, "maximum": 262144 },
            "max_in_flight": { "type": "integer", "minimum": 1, "maximum": 16 }
          },
          "additionalProperties": false
        }
      ]
    },
    "helloAck": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "extension_version", "executor"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "hello_ack" },
            "extension_version": { "type": "string", "minLength": 1 },
            "executor": { "enum": ["service_worker", "offscreen"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "requestHead": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "method", "url", "headers"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "request.head" },
            "id": { "$ref": "#/$defs/requestId" },
            "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"] },
            "url": { "type": "string", "format": "uri", "pattern": "^https://" },
            "headers": { "$ref": "#/$defs/headers" }
          },
          "additionalProperties": false
        }
      ]
    },
    "requestBody": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "seq", "data", "end"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "request.body" },
            "id": { "$ref": "#/$defs/requestId" },
            "seq": { "type": "integer", "minimum": 0 },
            "data": { "type": "string", "contentEncoding": "base64", "maxLength": 349528 },
            "end": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "requestAbort": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "reason"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "request.abort" },
            "id": { "$ref": "#/$defs/requestId" },
            "reason": {
              "enum": [
                "client_cancelled",
                "client_disconnected",
                "timeout",
                "host_shutdown"
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "responseHead": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "status", "headers"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "response.head" },
            "id": { "$ref": "#/$defs/requestId" },
            "status": { "type": "integer", "minimum": 100, "maximum": 599 },
            "headers": { "$ref": "#/$defs/headers" },
            "timing": { "$ref": "#/$defs/browserTiming" }
          },
          "additionalProperties": false
        }
      ]
    },
    "responseBody": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "seq", "data", "end"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "response.body" },
            "id": { "$ref": "#/$defs/requestId" },
            "seq": { "type": "integer", "minimum": 0 },
            "data": { "type": "string", "contentEncoding": "base64", "maxLength": 349528 },
            "end": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "flowAck": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "stream", "seq"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "flow.ack" },
            "id": { "$ref": "#/$defs/requestId" },
            "stream": { "enum": ["request", "response"] },
            "seq": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      ]
    },
    "messageError": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "code", "message", "retryable"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "error" },
            "id": { "$ref": "#/$defs/requestId" },
            "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
            "message": { "type": "string", "maxLength": 4096 },
            "retryable": { "type": "boolean" },
            "timing": { "$ref": "#/$defs/browserTiming" }
          },
          "additionalProperties": false
        }
      ]
    },
    "ping": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "nonce"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "ping" },
            "nonce": { "type": "string", "minLength": 1, "maxLength": 64 }
          },
          "additionalProperties": false
        }
      ]
    },
    "pong": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "nonce"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "pong" },
            "nonce": { "type": "string", "minLength": 1, "maxLength": 64 }
          },
          "additionalProperties": false
        }
      ]
    },
    "codexMode": {
      "enum": ["direct", "browser_lean", "browser_full", "unmanaged"]
    },
    "controlModeGet": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "control.mode.get" },
            "id": { "$ref": "#/$defs/requestId" }
          },
          "additionalProperties": false
        }
      ]
    },
    "controlModeSet": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "mode"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "control.mode.set" },
            "id": { "$ref": "#/$defs/requestId" },
            "mode": { "enum": ["direct", "browser_lean", "browser_full"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "controlModeResult": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "ok", "mode", "restart_vscode_required"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "control.mode.result" },
            "id": { "$ref": "#/$defs/requestId" },
            "ok": { "type": "boolean" },
            "mode": { "$ref": "#/$defs/codexMode" },
            "restart_vscode_required": { "type": "boolean" },
            "message": { "type": "string", "maxLength": 512 }
          },
          "additionalProperties": false
        }
      ]
    },
    "controlAntigravityGet": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "control.antigravity.get" },
            "id": { "$ref": "#/$defs/requestId" }
          },
          "additionalProperties": false
        }
      ]
    },
    "controlAntigravitySetup": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "control.antigravity.setup" },
            "id": { "$ref": "#/$defs/requestId" }
          },
          "additionalProperties": false
        }
      ]
    },
    "antigravitySetupState": {
      "type": "object",
      "required": [
        "ready", "cli_installed", "extension_installed", "vscode_configured",
        "environment_configured", "restart_vscode_required"
      ],
      "properties": {
        "ready": { "type": "boolean" },
        "cli_installed": { "type": "boolean" },
        "extension_installed": { "type": "boolean" },
        "vscode_configured": { "type": "boolean" },
        "environment_configured": { "type": "boolean" },
        "restart_vscode_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "controlAntigravityResult": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["type", "id", "ok"],
          "properties": {
            "v": { "$ref": "#/$defs/protocolVersion" },
            "type": { "const": "control.antigravity.result" },
            "id": { "$ref": "#/$defs/requestId" },
            "ok": { "type": "boolean" },
            "state": { "$ref": "#/$defs/antigravitySetupState" },
            "message": { "type": "string", "maxLength": 512 }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
