{
  "manifest_version": 3,
  "name": "FanVPN AI Bridge",
  "version": "2.2.2",
  "description": "Provides a loopback AI API bridge through Chrome and FanVPN.",
  "key": "",
  "minimum_chrome_version": "116",
  "permissions": [
    "nativeMessaging",
    "offscreen"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "FanVPN AI Bridge",
    "default_popup": "popup.html"
  }
}
