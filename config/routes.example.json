{
  "listen": {
    "host": "127.0.0.1",
    "port": 18888
  },
  "protocol": {
    "max_chunk_bytes": 262144,
    "max_in_flight": 4,
    "max_active_requests": 16,
    "max_request_body_bytes": 33554432,
    "request_timeout_seconds": 600
  },
  "routes": {
    "openai": {
      "upstream_base_url": "https://api.openai.com",
      "remove_path_prefix": "",
      "probe_path": "/v1/models"
    },
    "chatgpt-codex": {
      "upstream_base_url": "https://chatgpt.com/backend-api/codex",
      "remove_path_prefix": "",
      "probe_path": "/models"
    },
    "chatgpt-backend": {
      "upstream_base_url": "https://chatgpt.com",
      "remove_path_prefix": "",
      "probe_path": "/backend-api/codex/models"
    },
    "auth-openai": {
      "upstream_base_url": "https://auth.openai.com",
      "remove_path_prefix": "",
      "probe_path": "/"
    },
    "anthropic": {
      "upstream_base_url": "https://api.anthropic.com",
      "remove_path_prefix": "",
      "probe_path": "/v1/models"
    },
    "gemini": {
      "upstream_base_url": "https://generativelanguage.googleapis.com",
      "remove_path_prefix": "",
      "probe_path": "/v1beta/models",
      "request_header_allowlist": [
        "accept",
        "authorization",
        "content-type",
        "x-goog-api-key"
      ]
    },
    "gemini-openai": {
      "upstream_base_url": "https://generativelanguage.googleapis.com/v1beta/openai",
      "remove_path_prefix": "/v1",
      "probe_path": "/v1/models",
      "request_header_allowlist": [
        "accept",
        "authorization",
        "content-type",
        "x-goog-api-key"
      ]
    }
  }
}
